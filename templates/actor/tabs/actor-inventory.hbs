<div class="tab inventory {{tabs.inventory.cssClass}}" data-group="primary" data-tab="inventory">
  <div class="header-buttons">
    <button type="button" class="action-btn small" data-action="openWeaponBrowser"
      title="Adicionar Arma do Compêndio">
      <i class="fas fa-search"></i>Compêndio
    </button>
    <button type="button" class="action-btn small" data-action="openWeaponCreator" data-type="weapon">
      <i class="fas fa-plus"></i>Criar
    </button>
  </div>
  <div class="inventory-sidebar">
    {{!-- Seção de Armas --}}
    <div class="inventory-section">
      <div class="section-header header-with-action">
        <div class="header-content">
          <h3><i class="fas fa-swords"></i>Armas</h3>
        </div>
      </div>
      <ul class="item-list">
        {{#each weapons as |item|}}
        <li class="item-row" data-item-id="{{item.id}}" draggable="true">
          <div class="item-name">
            <span class="name-wrapper">
              <a class="item-edit" data-action="editItem">{{item.name}}</a>
              <span class="item-type-tag">{{localize (concat "ANIMUS.WeaponType." item.system.type)}}</span>
            </span>
          </div>
          <div class="item-controls">
            <a class="item-control {{#if item.system.equipped}}active{{/if}}" data-action="toggleEquip"
              title="Equipar/Desequipar">
              <i class="fas fa-hand-holding-magic"></i>
            </a>
            <a class="item-control" data-action="deleteItem" title="Excluir"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ul>
    </div>

    {{!-- Seção de Proteções --}}
    <div class="inventory-section">
      <div class="section-header header-with-action">
        <div class="header-content">
          <h3><i class="fas fa-shield-halved"></i>Proteções</h3>
        </div>
      </div>
      <ul class="item-list">
        {{#each gear.armor as |item|}}
        <li class="item-row" data-item-id="{{item.id}}" draggable="true">
          <div class="item-name">
            <img src="{{item.img}}" width="28" height="28" class="item-img" />
            <a class="item-edit" data-action="editItem">{{item.name}} ({{item.system.type}})</a>
          </div>
          <div class="item-controls">
            <a class="item-control {{#if item.system.equipped}}active{{/if}}" data-action="toggleEquip" title="Equipar">
              <i class="fas fa-shirt"></i>
            </a>
            <a class="item-control" data-action="deleteItem" title="Excluir"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
        {{#each gear.shield as |item|}}
        <li class="item-row" data-item-id="{{item.id}}" draggable="true">
          <div class="item-name">
            <img src="{{item.img}}" width="28" height="28" class="item-img" />
            <a class="item-edit" data-action="editItem">{{item.name}}</a>
          </div>
          <div class="item-controls">
            <a class="item-control {{#if item.system.equipped}}active{{/if}}" data-action="toggleEquip" title="Equipar">
              <i class="fas fa-shield"></i>
            </a>
            <a class="item-control" data-action="deleteItem" title="Excluir"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ul>
    </div>

    {{!-- Seção de Secundários --}}
    <div class="inventory-section">
      <div class="section-header header-with-action">
        <div class="header-content">
          <h3><i class="fas fa-backpack"></i>Secundários</h3>
        </div>
      </div>
      <ul class="item-list">
        {{#each gear.secondary as |item|}}
        <li class="item-row" data-item-id="{{item.id}}" draggable="true">
          <div class="item-name">
            <img src="{{item.img}}" width="28" height="28" class="item-img" />
            <span class="name-wrapper">
              <a class="item-edit" data-action="editItem">{{item.name}}</a>
              <span class="item-qty">x{{item.system.quantity}}</span>
            </span>
          </div>
          <div class="item-controls">
            {{#if item.system.consumable}}
            <a class="item-control" data-action="useItem" title="Usar Item">
              <i class="fas fa-wine-bottle"></i>
            </a>
            {{/if}}
            <a class="item-control" data-action="deleteItem" title="Excluir"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ul>
    </div>

  </div>

</div>