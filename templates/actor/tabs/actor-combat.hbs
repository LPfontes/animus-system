<div class="tab combat {{tabs.combat.cssClass}}" data-group="primary" data-tab="combat">

  <div class="main-profile-layout">
    {{> "systems/animus/templates/actor/parts/actor-portrait-stats.hbs"}}

    {{!-- Coluna Direita: Conteúdo de Combate --}}
      {{!-- Grade de Talentos e Ações --}}
      {{> "systems/animus/templates/actor/parts/actor-talents-grid.hbs" isCombatTab=true}}

  </div>
  <div class="grid grid-2">
    {{!-- Seção de Armas --}}
    <div class="combat-section">
      <div class="weapons-modern-list">
        <div class="list-header">
          <div class="col-name">{{localize "ANIMUS.Weapon"}}</div>
          <div class="col-ac">PA</div>
          <div class="col-ac">AC1</div>
          <div class="col-ac">AC2</div>
          <div class="col-ac">AC3</div>
          <div class="col-ac">AC4</div>
        </div>

        <div class="list-body">
          {{#each weapons as |weapon|}}
          <div class="weapon-item-row item-row glass-row" data-item-id="{{weapon.id}}" draggable="true">
            <div class="item-main-info">
              <div class="roll-icon-btn" data-action="rollWeapon" title="Rolar Ataque">
                <i class="fas fa-dice-d20"></i>
              </div>
              <img src="{{weapon.img}}" class="item-icon-small" />
              <span class="item-name-clickable" data-action="editItem">{{weapon.name}}</span>
            </div>
            <div class="col-ac pa-value" style="color: var(--accent); font-weight: 800;">{{weapon.system.cost}}</div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac1}}
            </div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac2}}
            </div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac3}}
            </div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac4}}
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>

  {{!-- Terceira Coluna: Ações Básicas e Rápidas --}}
  <div class="combat-content-column expanded">
    <div class="section-header header-with-action">
      <div class="header-content">
        <button type="button" class="action-btn small toggle-accordion-btn" data-action="toggleActionDescription" title="Expandir/Recolher">
          <h3 class="category-title">
            <span class="text-expanded">OCULTAR</span><span class="text-collapsed">EXIBIR</span> AÇÕES
          </h3>
          <i class="fas fa-chevron-up"></i>
        </button>
      </div>
    </div>
    <div class="actions-modern-list">
      {{!-- Uso Elemental --}}
      <div class="action-item-row glass-row basic-action elemental-action" data-action="toggleActionDescription" draggable="true">
        <div class="action-row-main">
          <div class="item-main-info">
            <div class="roll-icon-btn" data-action="rollElemental" data-name="Uso Elemental">
              <i class="fas fa-play"></i>
            </div>
            <span class="item-name">Uso Elemental</span>
          </div>
        </div>
        <div class="action-description">Ativa o uso elemental do seu elemento, consultando a tabela de dano ou cura.</div>
      </div>

      {{!-- Ações Básicas (Sempre Visíveis) --}}
      {{#each config.basicActions as |action|}}
      {{#unless (or (eq action.name 'Uso Elemental') (eq action.name 'Atacar'))}}
      <div class="action-item-row glass-row basic-action" data-action="toggleActionDescription" draggable="true">
        <div class="action-row-main">
          <div class="item-main-info">
            <div class="roll-icon-btn" data-action="rollBasicAction" data-name="{{action.name}}">
              <i class="fas fa-play"></i>
            </div>
            <span class="item-name">{{action.name}}</span>
          </div>
          
          <div class="item-tags">
            <span class="tag cost">{{action.cost}} PA</span>
          </div>
        </div>
        <div class="action-description">{{action.description}}</div>
      </div>
      {{/unless}}
      {{/each}}

      {{!-- Ações Customizadas/Adquiridas --}}
      {{#each actions as |action|}}
      <div class="action-item-row glass-row item-row" data-item-id="{{action.id}}" data-action="toggleActionDescription" draggable="true">
        <div class="action-row-main">
          <div class="item-main-info">
            <div class="roll-icon-btn" data-action="useItem" title="Usar Ação">
              <i class="fas fa-play"></i>
            </div>
            <span class="item-name-clickable" data-action="editItem">{{action.name}}</span>
          </div>
          <div class="item-tags">
            {{#if action.system.cost}}<span class="tag cost">{{action.system.cost}} PA</span>{{/if}}
            {{#if action.system.range}}<span class="tag range">{{action.system.range}}</span>{{/if}}
          </div>
        </div>
        {{#if action.system.description}}
        <div class="action-description">{{{action.system.description}}}</div>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div> 


  </div>

  <div class="combat-tables">
    {{!-- Tabela de Dano Elemental --}}
    {{#if element.resolvedDamageTable}}
    <div class="element-damage-table-panel" data-action="toggleActionDescription">
      <div class="edt-header">
        <i class="fas fa-fire"></i>
        <span>
          <span class="text-expanded">OCULTAR</span><span class="text-collapsed">EXIBIR</span> {{element.name}} — Tabela de Dano (ANI {{system.attributes.ani.value}})
        </span>
      </div>
      <div class="edt-body">
        <table class="edt-table">
          <thead>
          <tr>
            <th>Nível</th>
            <th>PE</th>
            <th>AC 1</th>
            <th>AC 2</th>
            <th>AC 3</th>
            <th><i class="fas fa-star"></i>AC 4</th>
          </tr>
        </thead>
        <tbody>
          {{#each element.resolvedDamageTable as |tier key|}}
          <tr>
            <td class="tier-label">{{key}}</td>
            <td class="pe-cost">{{tier.pe}} PE</td>
            <td>{{tier.ac1.total}} <span class="formula">({{tier.ac1.label}})</span></td>
            <td>{{tier.ac2.total}} <span class="formula">({{tier.ac2.label}})</span></td>
            <td>{{tier.ac3.total}} <span class="formula">({{tier.ac3.label}})</span></td>
            <td>{{tier.ac4.total}} <span class="formula">({{tier.ac4.label}})</span></td>
          </tr>
          {{/each}}
        </table>
      </div>
    </div>
    {{/if}}

    {{!-- Tabela de Cura do Elemento --}}
    {{#if element.resolvedHealTable}}
    <div class="element-damage-table-panel heal-panel" data-action="toggleActionDescription">
      <div class="edt-header heal-header">
        <i class="fas fa-heart"></i>
        <span>
          <span class="text-expanded">OCULTAR</span><span class="text-collapsed">EXIBIR</span> {{element.name}} — Tabela de Cura (ANI {{system.attributes.ani.value}})
        </span>
      </div>
      <div class="edt-body">
        <table class="edt-table">
          <thead>
          <tr>
            <th>Nível</th>
            <th>PE</th>
            <th>AC 1</th>
            <th>AC 2</th>
            <th>AC 3</th>
            <th><i class="fas fa-star"></i>AC 4</th>
          </tr>
        </thead>
        <tbody>
          {{#each element.resolvedHealTable as |tier key|}}
          <tr>
            <td class="tier-label">{{key}}</td>
            <td class="pe-cost">{{tier.pe}} PE</td>
            <td>{{tier.ac1.total}} <span class="formula">({{tier.ac1.label}})</span></td>
            <td>{{tier.ac2.total}} <span class="formula">({{tier.ac2.label}})</span></td>
            <td>{{tier.ac3.total}} <span class="formula">({{tier.ac3.label}})</span></td>
            <td class="ac4-crit">{{tier.ac4.total}} <span class="formula">({{tier.ac4.label}})</span></td>
          </tr>
          {{/each}}
        </table>
      </div>
    </div>
    {{/if}}
  </div>

</div>