<div class="tab combat {{tabs.combat.cssClass}}" data-group="primary" data-tab="combat">

  <div class="main-profile-layout">
    {{!-- Coluna Esquerda: Retrato e Status --}}
    <div class="portrait-stats-column">
      <div class="portrait-frame">
        <img src="{{actor.img}}" data-edit="img" data-action="editImage" title="{{actor.name}}" />

        {{!-- Status Sobreposto ao Topo (Não Contido) --}}
        <div class="floating-stats-overlay">
          {{!-- Vida (PV) com Defesa Sobreposta --}}
          <div class="stat-group hp relative-container">
            <div class="stat-label">VIDA (PV)</div>
            <div class="bar-with-icon">
              <div class="bar-track">
                <div class="bar-ghost hp" style="width: {{hpPercent}}%"></div>
                <div class="bar-fill hp" style="width: {{hpPercent}}%"></div>
                <div class="bar-values-overlay">
                  <div class="stat-values">
                    <input type="number" data-path="system.status.hp.value" value="{{system.status.hp.value}}"
                      class="stat-input-overlay stat-sync-input" data-dtype="Number" />
                    <span class="stat-sep">/</span>
                    <span class="stat-max-overlay">{{system.status.hp.max}}</span>
                  </div>

                </div>
              </div>
            </div>

            {{!-- Escudo Flutuante sobre a Vida --}}
            <div class="defense-floating-on-hp">
              <span class="defense-label">{{localize "ANIMUS.Protection"}}</span>
              <div class="defense-mini-box">
                <i class="fas fa-shield shield-icon-mini"></i>
                <div class="stat-label-mini">
                  <input type="number" data-path="system.status.prot.value" value="{{system.status.prot.value}}"
                    class="defense-value-mini stat-sync-input" data-dtype="Number" />
                </div>
              </div>
            </div>
          </div>

          {{!-- Segunda Linha: PE e PA --}}
          <div class="overlay-secondary-row-v4">
            <div class="stat-group pe">
              <div class="stat-label">PE</div>
              <div class="bar-with-icon">
                <div class="bar-track">
                  <div class="bar-ghost pe" style="width: {{pePercent}}%"></div>
                  <div class="bar-fill pe" style="width: {{pePercent}}%"></div>
                  <div class="bar-values-overlay">
                    <input type="number" data-path="system.status.pe.value" value="{{system.status.pe.value}}"
                      class="stat-input-overlay stat-sync-input" data-dtype="Number" />
                    <span class="stat-sep">/</span>
                    <span class="stat-max-overlay">{{system.status.pe.max}}</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="stat-group pa">
              <div class="stat-label">PA</div>
              <div class="pa-pips-v3">
                {{#each paPips}}
                <div class="pa-pip {{#if filled}}filled{{/if}}" data-action="updatePA" data-value="{{add @index 1}}">
                </div>
                {{/each}}
              </div>
              {{#if system.status.pa.debt}}
              <div class="pa-debt-display" title="PA gasto do próximo turno (Reação)">
                <i class="fas fa-undo"></i> -{{system.status.pa.debt}}
                <a class="pa-debt-control" data-action="updatePADebt" data-delta="-1"><i
                    class="fas fa-minus-circle"></i></a>
              </div>
              {{else}}
              <a class="pa-debt-control add" data-action="updatePADebt" data-delta="1"
                title="Gastar PA da rodada seguinte (Reação)">
                <i class="fas fa-plus-circle"></i>
              </a>
              {{/if}}
            </div>
          </div>
        </div>
      </div>
    </div>

    {{!-- Coluna Direita: Conteúdo de Combate --}}
    <div class="combat-content-column">
      {{!-- Grade de Talentos e Ações --}}
      <div class="talents-grid-column combat-talents">
        <div class="header-with-action">
          <div class="header-content">
            <h3 class="category-title">TALENTOS E AÇÕES</h3>
          </div>
          <button type="button" class="action-btn small" data-action="openTalentManager" title="Gerenciar Talentos">
            <i class="fas fa-cog"></i> Gerenciar
          </button>
        </div>

        <div class="category-filters">
          <button type="button" class="category-btn {{#if (eq filters.talents 'all')}}active{{/if}}"
            data-action="filterTalents" data-category="all">
            <i class="fas fa-th-large"></i>
          </button>
          {{#each talentCategories}}
          <button type="button" class="category-btn {{#if (eq ../filters.talents this.id)}}active{{/if}}"
            data-action="filterTalents" data-category="{{this.id}}" title="{{this.label}}">
            <i class="{{this.icon}}"></i>
          </button>
          {{/each}}
        </div>

        <div class="talents-scroll-list">
          {{!-- Habilidades Inatas da Ascendência (respeitam o filtro) --}}
          {{#if showInnate}}
          {{#each ascendancy.system.innateAbilities as |ability|}}
          <div class="talent-card glass-panel innate" title="Habilidade Inata ({{../ascendancy.name}})">
            <div class="talent-header">
              <span class="talent-name"><i class="fas fa-dna mini-icon"></i> {{ability.name}}</span>
            </div>
            <div class="talent-body">
              {{#if ability.mechanicalEffect}}<strong>{{{ability.mechanicalEffect}}}</strong><br>{{/if}}
              {{{ability.description}}}
            </div>
          </div>
          {{/each}}
          {{/if}}

          {{!-- Talentos Filtrados --}}
          {{#each talents as |talent|}}
          <div class="talent-card glass-panel item-row" data-item-id="{{talent.id}}">
            <div class="talent-header">
              <div class="talent-name-wrapper">
                <span class="talent-name">{{talent.name}}</span>
                <span class="talent-category-tag">{{talent.system.subCategory}}</span>
              </div>
              <div class="talent-controls">
                <a class="talent-control edit" data-action="editItem" title="Editar"><i class="fas fa-edit"></i></a>
                <a class="talent-control delete" data-action="deleteItem" title="Excluir"><i
                    class="fas fa-trash"></i></a>
              </div>
            </div>
            {{#if talent.system.description}}
            <div class="talent-body">
              {{{talent.system.description}}}
            </div>
            {{/if}}
          </div>
          {{/each}}

          {{!-- Ações --}}
          {{#each actions as |action|}}
          <div class="talent-card glass-panel action item-row" data-item-id="{{action.id}}">
            <div class="talent-header">
              <div class="talent-name-wrapper">
                <span class="talent-name"><i class="fas fa-bolt mini-icon"></i> {{action.name}}</span>
              </div>
              <div class="talent-controls">
                <a class="talent-control edit" data-action="editItem" title="Editar"><i class="fas fa-edit"></i></a>
                <a class="talent-control delete" data-action="deleteItem" title="Excluir"><i
                    class="fas fa-trash"></i></a>
              </div>
            </div>
            {{#if action.system.description}}
            <div class="talent-body">
              {{{action.system.description}}}
            </div>
            {{/if}}
          </div>
          {{/each}}

          {{#if (and (not ascendancy.system.innateAbilities.length) (not talents.length) (not actions.length))}}
          <div class="empty-state">Nenhum talento ou ação disponível</div>
          {{/if}}
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-2">
    {{!-- Seção de Armas --}}
    <div class="combat-section">
      <div class="header-with-action">
        <div class="header-content">
          <h3 class="category-title">ARMAS</h3>
        </div>
        <div class="header-buttons">
          <button type="button" class="action-btn small" data-action="openWeaponBrowser"
            title="Adicionar Arma do Compêndio">
            <i class="fas fa-search"></i> Compêndio
          </button>
          <button type="button" class="action-btn small" data-action="openWeaponCreator" data-type="weapon">
            <i class="fas fa-plus"></i> Criar
          </button>
        </div>
      </div>
      <div class="weapons-modern-list">
        <div class="list-header">
          <div class="col-name">{{localize "ANIMUS.Weapon"}}</div>
          <div class="col-ac">PA</div>
          <div class="col-ac">AC1</div>
          <div class="col-ac">AC2</div>
          <div class="col-ac">AC3</div>
          <div class="col-ac">AC4</div>
        </div>

        <div class="list-body">
          {{#each weapons as |weapon|}}
          <div class="weapon-item-row item-row glass-row" data-item-id="{{weapon.id}}">
            <div class="item-main-info">
              <div class="roll-icon-btn" data-action="rollWeapon" title="Rolar Ataque">
                <i class="fas fa-dice-d20"></i>
              </div>
              <img src="{{weapon.img}}" class="item-icon-small" />
              <span class="item-name-clickable" data-action="editItem">{{weapon.name}}</span>
            </div>
            <div class="col-ac pa-value" style="color: var(--accent); font-weight: 800;">{{weapon.system.cost}}</div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac1}}
            </div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac2}}
            </div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac3}}
            </div>
            <div class="col-ac">
              {{weapon.system.damageTable.ac4}}
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>

    {{!-- Seção de Ações --}}
    <div class="combat-section">
      <div class="header-with-action">
        <div class="header-content">
          <h3 class="category-title">AÇÕES</h3>
        </div>
      </div>
      <div class="actions-modern-list">
        {{!-- Ações Básicas (Sempre Visíveis) --}}
        {{#each config.basicActions as |action|}}
        {{#if (eq action.name "Uso Elemental")}}
        <div class="action-item-row glass-row basic-action elemental-action" data-action="rollElemental" data-name="{{action.name}}">
          <div class="item-main-info">
            <div class="roll-icon-btn">
              <i class="fas fa-play"></i>
            </div>
            <i class="fas fa-star item-icon-small" style="color: var(--accent); font-size: 1.4em; width:28px; text-align:center;"></i>
            <span class="item-name">{{action.name}}</span>
          </div>
          <div class="item-tags">
            <span class="tag cost">{{action.cost}} PA</span>
            <span class="tag" style="background: color-mix(in srgb, var(--accent) 20%, transparent);">Elemental</span>
          </div>
        </div>
        {{else}}
        <div class="action-item-row glass-row basic-action" data-action="rollBasicAction" data-name="{{action.name}}">
          <div class="item-main-info">
            <div class="roll-icon-btn">
              <i class="fas fa-play"></i>
            </div>
            <img src="{{action.img}}" class="item-icon-small" />
            <span class="item-name">{{action.name}}</span>
          </div>
          <div class="item-tags">
            <span class="tag cost">{{action.cost}} PA</span>
          </div>
        </div>
        {{/if}}
        {{/each}}

        {{!-- Ações Customizadas/Adquiridas --}}
        {{#each actions as |action|}}
        <div class="action-item-row item-row glass-row" data-item-id="{{action.id}}">
          <div class="item-main-info">
            <div class="roll-icon-btn" data-action="useItem" title="Usar Ação">
              <i class="fas fa-play"></i>
            </div>
            <img src="{{action.img}}" class="item-icon-small" />
            <span class="item-name-clickable" data-action="editItem">{{action.name}}</span>
          </div>
          <div class="item-tags">
            {{#if action.system.cost}}<span class="tag cost">{{action.system.cost}} PA</span>{{/if}}
            {{#if action.system.range}}<span class="tag range">{{action.system.range}}</span>{{/if}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </div>

  <div class="combat-tables">
    {{!-- Tabela de Dano Elemental --}}
    {{#if element.resolvedDamageTable}}
    <div class="element-damage-table-panel">
      <div class="edt-header">
        <i class="fas fa-fire"></i>
        <span>{{element.name}} — Tabela de Dano (ANI {{system.attributes.ani.value}})</span>
      </div>
      <table class="edt-table">
        <thead>
          <tr>
            <th>Nível</th>
            <th>PE</th>
            <th>AC 1</th>
            <th>AC 2</th>
            <th>AC 3</th>
            <th><i class="fas fa-star"></i>AC 4</th>
          </tr>
        </thead>
        <tbody>
          {{#each element.resolvedDamageTable as |tier key|}}
          <tr>
            <td class="tier-label">{{key}}</td>
            <td class="pe-cost">{{tier.pe}} PE</td>
            <td>{{tier.ac1.total}} <span class="formula">({{tier.ac1.label}})</span></td>
            <td>{{tier.ac2.total}} <span class="formula">({{tier.ac2.label}})</span></td>
            <td>{{tier.ac3.total}} <span class="formula">({{tier.ac3.label}})</span></td>
            <td>{{tier.ac4.total}} <span class="formula">({{tier.ac4.label}})</span></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}

    {{!-- Tabela de Cura do Elemento --}}
    {{#if element.resolvedHealTable}}
    <div class="element-damage-table-panel heal-panel">
      <div class="edt-header heal-header">
        <i class="fas fa-heart"></i>
        <span>{{element.name}} — Tabela de Cura (ANI {{system.attributes.ani.value}})</span>
      </div>
      <table class="edt-table">
        <thead>
          <tr>
            <th>Nível</th>
            <th>PE</th>
            <th>AC 1</th>
            <th>AC 2</th>
            <th>AC 3</th>
            <th><i class="fas fa-star"></i>AC 4</th>
          </tr>
        </thead>
        <tbody>
          {{#each element.resolvedHealTable as |tier key|}}
          <tr>
            <td class="tier-label">{{key}}</td>
            <td class="pe-cost">{{tier.pe}} PE</td>
            <td>{{tier.ac1.total}} <span class="formula">({{tier.ac1.label}})</span></td>
            <td>{{tier.ac2.total}} <span class="formula">({{tier.ac2.label}})</span></td>
            <td>{{tier.ac3.total}} <span class="formula">({{tier.ac3.label}})</span></td>
            <td class="ac4-crit">{{tier.ac4.total}} <span class="formula">({{tier.ac4.label}})</span></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}
  </div>

</div>