<div class="portrait-stats-column">
  <div class="portrait-frame">
    <img src="{{actor.img}}" data-edit="img" data-action="editImage" title="{{actor.name}}" />

    {{!-- Status Sobreposto ao Topo --}}
    <div class="floating-stats-overlay">
      {{!-- Vida (PV) com Defesa Sobreposta --}}
      <div class="stat-group hp relative-container">
        <div class="stat-label">VIDA (PV)</div>
        <div class="bar-with-icon">
          <div class="bar-track">
            <div class="bar-ghost hp" style="width: {{hpPercent}}%"></div>
            <div class="bar-fill hp" style="width: {{hpPercent}}%"></div>
            <div class="bar-values-overlay">
              <div class="stat-values">
                <input type="number" name="system.status.hp.value" value="{{system.status.hp.value}}"
                  class="stat-input-overlay" data-dtype="Number" />
                <span class="stat-sep">/</span>
                <span class="stat-max-overlay">{{system.status.hp.max}}</span>
              </div>
            </div>
          </div>
        </div>

        {{!-- Escudo Flutuante sobre a Vida --}}
        <div class="defense-floating-on-hp">
          <span class="defense-label">PROTEÇÃO</span>
          <div class="defense-mini-box">
            <i class="fas fa-shield shield-icon-mini"></i>
            <div class="stat-label-mini">
              <input type="number" name="system.status.prot.value" value="{{system.status.prot.value}}"
                class="defense-value-mini" data-dtype="Number" />
            </div>
          </div>
        </div>
      </div>

      {{!-- Segunda Linha: PE e PA --}}
      <div class="overlay-secondary-row-v4">
        <div class="stat-group pe">
          <div class="stat-label">PE</div>
          <div class="bar-with-icon">
            <div class="bar-track">
              <div class="bar-ghost pe" style="width: {{pePercent}}%"></div>
              <div class="bar-fill pe" style="width: {{pePercent}}%"></div>
              <div class="bar-values-overlay">
                <input type="number" name="system.status.pe.value" value="{{system.status.pe.value}}"
                  class="stat-input-overlay" data-dtype="Number" />
                <span class="stat-sep">/</span>
                <span class="stat-max-overlay">{{system.status.pe.max}}</span>
              </div>
            </div>
          </div>
        </div>

        <div class="stat-group pa">
          <div class="stat-label">PA</div>
          <div class="pa-pips-v3">
            {{#each paPips}}
            <div class="pa-pip {{#if filled}}filled{{/if}}" data-action="updatePA" data-value="{{add @index 1}}">
            </div>
            {{/each}}
          </div>
          {{#if system.status.pa.debt}}
          <div class="pa-debt-display" title="PA gasto do próximo turno (Reação)">
            <i class="fas fa-undo"></i> -{{system.status.pa.debt}}
            <a class="pa-debt-control" data-action="updatePADebt" data-delta="-1"><i class="fas fa-minus-circle"></i></a>
          </div>
          {{else}}
          <a class="pa-debt-control add" data-action="updatePADebt" data-delta="1"
            title="Gastar PA da rodada seguinte (Reação)">
            <i class="fas fa-plus-circle"></i>
          </a>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</div>
