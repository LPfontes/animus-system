<div class="tab attributes {{tabs.attributes.cssClass}}" data-group="primary" data-tab="attributes">


  {{!-- Botão de Evolução (Apenas se houver pendências) --}}
  {{#if pendingAdvancement}}
  <div class="advancement-launcher glass-panel">
    <div class="launcher-label">
      <span><i class="fas fa-level-up-alt"></i> EVOLUÇÃO DISPONÍVEL</span>
      <p>Distribua seus pontos de nível e bônus de atributo.</p>
    </div>
    <div class="launcher-actions">
      <span class="points-badge {{#if (eq pointsRemaining 0)}}complete{{/if}}">
        Pontos: {{pointsRemaining}}
      </span>
      <button type="button" class="btn-open-advancement" data-action="openAdvancement">
        ABRIR PAINEL
      </button>
    </div>
  </div>
  {{/if}}

  {{!-- Header Superior com Dados Básicos --}}
  <div class="glass-panel header-info-row">
    <div class="input-group">
      <label class="input-label">NOME</label>
      <input name="name" type="text" value="{{actor.name}}" class="input-field" placeholder="Nome" />
    </div>
    <div class="input-group">
      <label class="input-label">NÍVEL</label>
      <input name="system.details.level" type="number" value="{{system.details.level}}" class="input-field" min="1"
        max="10" />
    </div>
    <div class="input-group drop-zone" data-type="ascendancy">
      <label class="input-label">ASCENDÊNCIA</label>
      <div class="item-slot {{#if ascendancy}}active{{/if}}">
        <span class="slot-text">{{#if ascendancy}}{{ascendancy.name}}{{else}}Selecionar{{/if}}</span>
        {{#if ascendancy}}
        <a class="slot-control delete" data-action="deleteItem" data-item-id="{{ascendancy.id}}"><i
            class="fas fa-times"></i></a>
        <a class="slot-control bonus-edit {{#unless ascendancy.system.bonus.selectedAttribute}}pending{{/unless}}"
          data-action="openBonusSelector" data-item-id="{{ascendancy.id}}" title="Selecionar Bônus">
          <i class="fas fa-plus-circle"></i>
        </a>
        {{/if}}
      </div>
    </div>
    <div class="input-group drop-zone" data-type="element">
      <label class="input-label">ELEMENTAL</label>
      <div class="item-slot {{#if element}}active{{/if}}">
        <span class="slot-text">{{#if element}}{{element.name}}{{else}}Selecionar{{/if}}</span>
        {{#if element}}
        <a class="slot-control delete" data-action="deleteItem" data-item-id="{{element.id}}"><i
            class="fas fa-times"></i></a>
        <a class="slot-control bonus-edit {{#unless element.system.bonus.selectedAttribute}}pending{{/unless}}"
          data-action="openBonusSelector" data-item-id="{{element.id}}" title="Selecionar Bônus">
          <i class="fas fa-plus-circle"></i>
        </a>
        {{/if}}
      </div>
    </div>

    <div class="input-group rest-group">
      <label class="input-label">DESCANSAR</label>
      <div class="rest-buttons">
        <button type="button" class="rest-btn short" data-action="shortRest" title="Descanso Curto (10-30 min)">
          <i class="fas fa-hourglass-half"></i> {{system.details.shortRests}}/2
        </button>
        <button type="button" class="rest-btn long" data-action="longRest" title="Descanso Longo (8h)">
          <i class="fas fa-bed"></i>
        </button>
      </div>
    </div>

    <div class="input-group gear-group">
      <button type="button" class="edit-mode-toggle {{#if editMode}}active{{/if}}" data-action="toggleEditMode"
        title="Modo de Edição Livre">
        <i class="fas fa-cog"></i>
      </button>
    </div>
  </div>

  <div class="main-profile-layout">
    {{> "systems/animus/templates/actor/parts/actor-portrait-stats.hbs"}}

    {{> "systems/animus/templates/actor/parts/actor-talents-grid.hbs" isCombatTab=false}}
  </div>

  {{!-- Grade de Habilidades --}}
  <div class="abilities-grid-column">
    <div class="abilities-header"
      style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; padding: 0 5px;">
      <h3 class="category-title" style="margin: 0;">PERÍCIAS</h3>
      <div class="header-status-pills" style="display: flex; gap: 15px;">
        <div class="status-item {{#if (eq attrCount attrLimit)}}complete{{/if}}"
          style="font-size: 1rem; font-weight: 700; color: {{#if (gt attrCount attrLimit)}}var(--fire){{else}}var(--accent){{/if}};"
          title="Pontos de Atributo">
          <i class="fas fa-star"></i> Atributos: {{attrCount}} / {{attrLimit}}
        </div>
        <div class="status-item {{#if (eq skillCount skillLimit)}}complete{{/if}}"
          style="font-size: 1rem; font-weight: 700; color: {{#if (gt skillCount skillLimit)}}var(--fire){{else}}var(--accent){{/if}};"
          title="Pontos de Perícia">
          <i class="fas fa-list-check"></i> Perícias: {{skillCount}} / {{skillLimit}}
        </div>
      </div>
    </div>
    <div class="abilities-categories-row">
      {{#each unifiedAbilities as |category|}}
      <div class="ability-category">
        <h3 class="category-title">{{category.title}}</h3>

        {{#each category.attributes as |attr|}}
        <div class="attribute-card glass-panel">
          <div class="attr-header">
            <a class="attr-name rollable" data-action="rollAttribute" data-attribute="{{attr.key}}">{{localize
              attr.label}}</a>
            <div class="attr-dots">
              {{#each (list 1 2 3)}}
              <a class="dot {{#if (gt attr.total (sub this 1))}}filled{{/if}} {{#if (and (gt attr.total (sub this 1)) (lte attr.base (sub this 1)))}}bonus-filled{{/if}}"
                data-action="updateAbility" data-ability="attributes.{{attr.key}}" data-value="{{this}}"></a>
              {{/each}}
            </div>
            <div class="attr-bonus-roll">
              <span class="attr-bonus">+{{attr.total}}</span>
              <a class="attr-roll-btn" data-action="rollAttribute" data-attribute="{{attr.key}}"
                title="Rolar Teste de {{localize attr.label}}">
                <i class="fas fa-dice-d20"></i>
              </a>
            </div>
          </div>

          <div class="skills-list">
            {{#each attr.skills as |skill|}}
            <div class="skill-row {{#if skill.active}}active{{/if}}">
              <span class="skill-name">{{localize skill.label}}</span>
              <div class="skill-controls">
                <div class="skill-boxes">
                  {{#each (list 1 2 3)}}
                  <a class="box {{#if (gt skill.value (sub this 1))}}filled{{/if}}" data-action="updateAbility"
                    data-ability="skills.{{skill.key}}" data-value="{{this}}"></a>
                  {{/each}}
                </div>
                <span class="skill-mod">{{skill.dice}}d</span>
                <a class="skill-roll-btn" data-action="rollSkill" data-skill="{{skill.key}}">
                  <i class="fas fa-dice-d20"></i>
                </a>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/each}}
    </div>
  </div>
</div>