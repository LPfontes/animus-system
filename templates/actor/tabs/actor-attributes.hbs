<div class="tab attributes {{tabs.attributes.cssClass}}" data-group="primary" data-tab="attributes">


  {{!-- Botão de Evolução (Apenas se houver pendências) --}}
  {{#if pendingAdvancement}}
  <div class="advancement-launcher glass-panel"
    style="margin-bottom: 20px; padding: 10px 15px; display: flex; justify-content: space-between; align-items: center; border-left: 3px solid var(--accent);">
    <div class="launcher-label">
      <span style="font-weight: 900; letter-spacing: 0.1em; color: var(--accent);"><i class="fas fa-level-up-alt"></i>
        EVOLUÇÃO DISPONÍVEL</span>
      <p style="margin: 0; font-size: 0.7rem; color: var(--text-muted);">Distribua seus pontos de nível e bônus de
        atributo.</p>
    </div>
    <div class="launcher-actions" style="display: flex; align-items: center; gap: 15px;">
      <span class="points-badge {{#if (eq pointsRemaining 0)}}complete{{/if}}"
        style="font-size: 0.75rem; font-weight: 800; background: rgba(157, 78, 221, 0.2); padding: 4px 12px; border-radius: 20px;">
        Pontos: {{pointsRemaining}}
      </span>
      <button type="button" class="btn-open-advancement" data-action="openAdvancement"
        style="background: var(--accent); color: #fff; border: none; padding: 6px 15px; border-radius: 4px; font-weight: 900; cursor: pointer; transition: transform 0.2s;">
        ABRIR PAINEL
      </button>
    </div>
  </div>
  {{/if}}

  {{!-- Header Superior com Dados Básicos --}}
  <div class="glass-panel header-info-row">
    <div class="input-group">
      <label class="input-label">NOME</label>
      <input name="name" type="text" value="{{actor.name}}" class="input-field" placeholder="Nome" />
    </div>
    <div class="input-group">
      <label class="input-label">NÍVEL</label>
      <input name="system.details.level" type="number" value="{{system.details.level}}" class="input-field" min="1"
        max="10" />
    </div>
    <div class="input-group drop-zone" data-type="ascendancy">
      <label class="input-label">ASCENDÊNCIA</label>
      <div class="item-slot {{#if ascendancy}}active{{/if}}">
        <span class="slot-text">{{#if ascendancy}}{{ascendancy.name}}{{else}}Selecionar{{/if}}</span>
        {{#if ascendancy}}
        <a class="slot-control delete" data-action="deleteItem" data-item-id="{{ascendancy.id}}"><i
            class="fas fa-times"></i></a>
        <a class="slot-control bonus-edit {{#unless ascendancy.system.bonus.selectedAttribute}}pending{{/unless}}"
          data-action="openBonusSelector" data-item-id="{{ascendancy.id}}" title="Selecionar Bônus">
          <i class="fas fa-plus-circle"></i>
        </a>
        {{/if}}
      </div>
    </div>
    <div class="input-group drop-zone" data-type="element">
      <label class="input-label">ELEMENTAL</label>
      <div class="item-slot {{#if element}}active{{/if}}">
        <span class="slot-text">{{#if element}}{{element.name}}{{else}}Selecionar{{/if}}</span>
        {{#if element}}
        <a class="slot-control delete" data-action="deleteItem" data-item-id="{{element.id}}"><i
            class="fas fa-times"></i></a>
        <a class="slot-control bonus-edit {{#unless element.system.bonus.selectedAttribute}}pending{{/unless}}"
          data-action="openBonusSelector" data-item-id="{{element.id}}" title="Selecionar Bônus">
          <i class="fas fa-plus-circle"></i>
        </a>
        {{/if}}
      </div>
    </div>

    <div class="input-group rest-group">
      <label class="input-label">DESCANSAR</label>
      <div class="rest-buttons" style="display: flex; gap: 5px;">
        <button type="button" class="rest-btn short" data-action="shortRest" title="Descanso Curto (10-30 min)"
          style="height: 42px; background: rgba(0, 242, 255, 0.1); border: 1px solid rgba(0, 242, 255, 0.3); color: #00f2ff; border-radius: 10px; cursor: pointer; padding: 0 10px; font-weight: 800; font-size: 0.7rem;">
          <i class="fas fa-hourglass-half"></i> {{system.details.shortRests}}/2
        </button>
        <button type="button" class="rest-btn long" data-action="longRest" title="Descanso Longo (8h)"
          style="height: 42px; background: rgba(157, 78, 221, 0.1); border: 1px solid rgba(157, 78, 221, 0.3); color: #9d4edd; border-radius: 10px; cursor: pointer; padding: 0 10px;">
          <i class="fas fa-bed"></i>
        </button>
      </div>
    </div>

    <div class="input-group gear-group">
      <button type="button" class="edit-mode-toggle {{#if editMode}}active{{/if}}" data-action="toggleEditMode"
        title="Modo de Edição Livre">
        <i class="fas fa-cog"></i>
      </button>
    </div>
  </div>

  <div class="main-profile-layout">
    {{!-- Coluna Esquerda: Retrato e Status --}}
    <div class="portrait-stats-column">
      <div class="portrait-frame">
        <img src="{{actor.img}}" data-edit="img" data-action="editImage" title="{{actor.name}}" />

        {{!-- Status Sobreposto ao Topo (Não Contido) --}}
        <div class="floating-stats-overlay">
          {{!-- Vida (PV) com Defesa Sobreposta --}}
          <div class="stat-group hp relative-container">
            <div class="stat-label">VIDA (PV)</div>
            <div class="bar-with-icon">
              <div class="bar-track">
                <div class="bar-ghost hp" style="width: {{hpPercent}}%"></div>
                <div class="bar-fill hp" style="width: {{hpPercent}}%"></div>
                <div class="bar-values-overlay">
                  <div class="stat-values">
                    <input type="number" data-path="system.status.hp.value" value="{{system.status.hp.value}}"
                      class="stat-input-overlay stat-sync-input" data-dtype="Number" />
                    <span class="stat-sep">/</span>
                    <span class="stat-max-overlay">{{system.status.hp.max}}</span>
                  </div>

                </div>
              </div>
            </div>

            {{!-- Escudo Flutuante sobre a Vida --}}
            <div class="defense-floating-on-hp">
              <span class="defense-label">{{localize "ANIMUS.Protection"}}</span>
              <div class="defense-mini-box">
                <i class="fas fa-shield shield-icon-mini"></i>
                <div class="stat-label-mini">
                  <input type="number" data-path="system.status.prot.value" value="{{system.status.prot.value}}"
                    class="defense-value-mini stat-sync-input" data-dtype="Number" />
                </div>
              </div>
            </div>
          </div>

          {{!-- Segunda Linha: PE e PA --}}
          <div class="overlay-secondary-row-v4">
            <div class="stat-group pe">
              <div class="stat-label">PE</div>
              <div class="bar-with-icon">
                <div class="bar-track">
                  <div class="bar-ghost pe" style="width: {{pePercent}}%"></div>
                  <div class="bar-fill pe" style="width: {{pePercent}}%"></div>
                  <div class="bar-values-overlay">
                    <input type="number" data-path="system.status.pe.value" value="{{system.status.pe.value}}"
                      class="stat-input-overlay stat-sync-input" data-dtype="Number" />
                    <span class="stat-sep">/</span>
                    <span class="stat-max-overlay">{{system.status.pe.max}}</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="stat-group pa">
              <div class="stat-label">PA</div>
              <div class="pa-pips-v3">
                {{#each paPips}}
                <div class="pa-pip {{#if filled}}filled{{/if}}" data-action="updatePA" data-value="{{add @index 1}}">
                </div>
                {{/each}}
              </div>
              {{#if system.status.pa.debt}}
              <div class="pa-debt-display" title="PA gasto do próximo turno (Reação)">
                <i class="fas fa-undo"></i> -{{system.status.pa.debt}}
                <a class="pa-debt-control" data-action="updatePADebt" data-delta="-1"><i
                    class="fas fa-minus-circle"></i></a>
              </div>
              {{else}}
              <a class="pa-debt-control add" data-action="updatePADebt" data-delta="1"
                title="Gastar PA da rodada seguinte (Reação)">
                <i class="fas fa-plus-circle"></i>
              </a>
              {{/if}}
            </div>
          </div>
        </div>
      </div>
    </div>

    {{!-- Coluna Direita (Retrato): Grade de Talentos --}}
    <div class="talents-grid-column">
      <div class="header-with-action">
        <div class="header-content">
          <h3 class="category-title">TALENTOS</h3>
          <div class="status-item {{#if (eq talentCount 2)}}complete{{/if}}"
            style="font-size: 0.75rem; font-weight: 700; color: {{#if (gt talentCount 2)}}var(--fire){{else}}var(--accent){{/if}};">
            <i class="fas fa-brain"></i> {{talentCount}} / 2
          </div>
        </div>

        <button type="button" class="action-btn small" data-action="openTalentManager" title="Gerenciar Talentos">
          <i class="fas fa-cog"></i> Gerenciar
        </button>
      </div>

      <div class="category-filters">
        <button type="button" class="category-btn {{#if (eq filters.talents 'all')}}active{{/if}}"
          data-action="filterTalents" data-category="all">
          <i class="fas fa-th-large"></i>
        </button>
        {{#each talentCategories}}
        <button type="button" class="category-btn {{#if (eq ../filters.talents this.id)}}active{{/if}}"
          data-action="filterTalents" data-category="{{this.id}}" title="{{this.label}}">
          <i class="{{this.icon}}"></i>
        </button>
        {{/each}}
      </div>

      <div class="talents-scroll-list">
        {{!-- Habilidades Inatas da Ascendência --}}
        {{#each ascendancy.system.innateAbilities as |ability|}}
        <div class="talent-card glass-panel innate" title="Habilidade Inata ({{../ascendancy.name}})">
          <div class="talent-header">
            <span class="talent-name"><i class="fas fa-dna mini-icon"></i> {{ability.name}}</span>
          </div>
          <div class="talent-body">
            {{#if ability.mechanicalEffect}}<strong>{{{ability.mechanicalEffect}}}</strong><br>{{/if}}
            {{{ability.description}}}
          </div>
        </div>
        {{/each}}

        {{#each talents as |talent|}}
        <div class="talent-card glass-panel item-row" data-item-id="{{talent.id}}">
          <div class="talent-header">
            <div class="talent-name-wrapper">
              <span class="talent-name">{{talent.name}}</span>
              <span class="talent-category-tag">{{talent.system.subCategory}}</span>
            </div>
            <div class="talent-controls">
              <a class="talent-control edit" data-action="editItem" title="Editar"><i class="fas fa-edit"></i></a>
              <a class="talent-control delete" data-action="deleteItem" title="Excluir"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{#if talent.system.description}}
          <div class="talent-body">
            {{{talent.system.description}}}
          </div>
          {{/if}}
        </div>
        {{/each}}

        {{#if (and (not ascendancy.system.innateAbilities.length) (not talents.length))}}
        <div class="empty-state">Nenhum talento adquirido</div>
        {{/if}}
      </div>
    </div>
  </div>

  {{!-- Grade de Habilidades --}}
  <div class="abilities-grid-column">
    <div class="abilities-header"
      style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; padding: 0 5px;">
      <h3 class="category-title" style="margin: 0;">PERÍCIAS</h3>
      <div class="header-status-pills" style="display: flex; gap: 15px;">
        <div class="status-item {{#if (eq attrCount attrLimit)}}complete{{/if}}"
          style="font-size: 0.75rem; font-weight: 700; color: {{#if (gt attrCount attrLimit)}}var(--fire){{else}}var(--accent){{/if}};"
          title="Pontos de Atributo">
          <i class="fas fa-star"></i> Atributos: {{attrCount}} / {{attrLimit}}
        </div>
        <div class="status-item {{#if (eq skillCount skillLimit)}}complete{{/if}}"
          style="font-size: 0.75rem; font-weight: 700; color: {{#if (gt skillCount skillLimit)}}var(--fire){{else}}var(--accent){{/if}};"
          title="Pontos de Perícia">
          <i class="fas fa-list-check"></i> Perícias: {{skillCount}} / {{skillLimit}}
        </div>
      </div>
    </div>
    <div class="abilities-categories-row">
      {{#each unifiedAbilities as |category|}}
      <div class="ability-category">
        <h3 class="category-title">{{category.title}}</h3>

        {{#each category.attributes as |attr|}}
        <div class="attribute-card glass-panel">
          <div class="attr-header">
            <a class="attr-name rollable" data-action="rollAttribute" data-attribute="{{attr.key}}">{{localize attr.label}}</a>
            <div class="attr-dots">
              {{#each (list 1 2 3)}}
              <a class="dot {{#if (gt attr.value (sub this 1))}}filled{{/if}}" data-action="updateAbility"
                data-ability="attributes.{{attr.key}}" data-value="{{this}}"></a>
              {{/each}}
            </div>
            <div class="attr-bonus-roll">
              <span class="attr-bonus">+{{attr.value}}</span>
              <a class="attr-roll-btn" data-action="rollAttribute" data-attribute="{{attr.key}}" title="Rolar Teste de {{localize attr.label}}">
                <i class="fas fa-dice-d20"></i>
              </a>
            </div>
          </div>

          <div class="skills-list">
            {{#each attr.skills as |skill|}}
            <div class="skill-row {{#if skill.active}}active{{/if}}">
              <span class="skill-name">{{localize skill.label}}</span>
              <div class="skill-controls">
                <div class="skill-boxes">
                  {{#each (list 1 2 3)}}
                  <a class="box {{#if (gt skill.value (sub this 1))}}filled{{/if}}" data-action="updateAbility"
                    data-ability="skills.{{skill.key}}" data-value="{{this}}"></a>
                  {{/each}}
                </div>
                <span class="skill-mod">—</span>
                <a class="skill-roll-btn" data-action="rollSkill" data-skill="{{skill.key}}">
                  <i class="fas fa-dice-d20"></i>
                </a>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/each}}
    </div>
  </div>
</div>