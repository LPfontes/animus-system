<div class="tab biography {{tabs.description.cssClass}}" data-group="primary" data-tab="description">
  <div class="biography-layout">
    
    <!-- Top Section: Traits and Appearance -->
    <div class="bio-top-grid">
      <!-- Traits Column -->
      <div class="bio-column traits-column">
        <div class="glass-panel bio-section">
          <h3 class="section-title"><i class="fas fa-brain"></i> Personalidade</h3>
          <textarea name="system.details.personality" rows="3" placeholder="Traços de personalidade...">{{system.details.personality}}</textarea>
        </div>
        
        <div class="glass-panel bio-section">
          <h3 class="section-title"><i class="fas fa-star"></i> Ideais</h3>
          <textarea name="system.details.ideals" rows="2" placeholder="Ideais e crenças...">{{system.details.ideals}}</textarea>
        </div>

        <div class="glass-panel bio-section">
          <h3 class="section-title"><i class="fas fa-link"></i> Vínculos</h3>
          <textarea name="system.details.bonds" rows="2" placeholder="Pessoas ou lugares importantes...">{{system.details.bonds}}</textarea>
        </div>

        <div class="glass-panel bio-section">
          <h3 class="section-title"><i class="fas fa-exclamation-triangle"></i> Fraquezas</h3>
          <textarea name="system.details.flaws" rows="2" placeholder="Vícios e falhas...">{{system.details.flaws}}</textarea>
        </div>
      </div>

      <!-- Appearance and Notes Column -->
      <div class="bio-column appearance-column">
        <div class="glass-panel bio-section full-height">
          <h3 class="section-title"><i class="fas fa-eye"></i> Aparência</h3>
          <div class="editor-container">
            {{editor system.details.appearance target="system.details.appearance" button=true owner=owner editable=editable engine="prosemirror"}}
          </div>
        </div>
        
        <div class="glass-panel bio-section">
          <h3 class="section-title"><i class="fas fa-sticky-note"></i> Notas</h3>
          <div class="editor-container">
            {{editor system.details.notes target="system.details.notes" button=true owner=owner editable=editable engine="prosemirror"}}
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Section: Full Biography -->
    <div class="glass-panel bio-section biography-full">
      <h3 class="section-title"><i class="fas fa-history"></i> História do Personagem</h3>
      <div class="editor-container">
        {{editor system.details.biography target="system.details.biography" button=true owner=owner editable=editable engine="prosemirror"}}
      </div>
    </div>

  </div>
</div>
