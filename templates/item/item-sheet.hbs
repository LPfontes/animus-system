<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="Nome"/></h1>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">{{localize "ANIMUS.Description"}}</a>
    <a class="item" data-tab="details">{{localize "ANIMUS.Details"}}</a>
  </nav>

  <section class="sheet-body">
    {{!-- Aba de Descrição --}}
    <div class="tab description" data-group="primary" data-tab="description">
      {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>

    {{!-- Aba de Detalhes --}}
    <div class="tab details" data-group="primary" data-tab="details">
      {{!-- Efeito (Comum a todos os itens) --}}
      <div class="form-group stacked">
        <label>{{localize "ANIMUS.Effect"}}</label>
        {{editor system.effect target="system.effect" button=true owner=owner editable=editable}}
      </div>

      <hr>

      <hr>

      {{!-- Seção de Teste (Check) --}}
      <div class="check-section">
        <h3>{{localize "ANIMUS.Check"}}</h3>
        <div class="form-group">
          <label>{{localize "ANIMUS.Skill"}}</label>
          <select name="system.check.skill">
            <option value="-1"></option>
            {{#select system.check.skill}}
              {{#each config.skillsEnum as |name key|}}
                <option value="{{key}}">{{localize name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Attribute"}}</label>
          <select name="system.check.attribute">
            <option value="-1">{{localize "ANIMUS.AppNone"}}</option>
            {{#select system.check.attribute}}
              {{#each config.attributesEnum as |name key|}}
                <option value="{{key}}">{{name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.DC"}}</label>
          <input type="number" name="system.check.dc" value="{{system.check.dc}}"/>
        </div>
      </div>

      <hr>

      {{!-- Seção de Aplicação (Resultado) --}}
      <div class="application-section">
        <h3>{{localize "ANIMUS.Application"}}</h3>
        <div class="form-group">
          <label>{{localize "ANIMUS.Type"}}</label>
          <select name="system.application.type">
            {{#select system.application.type}}
              {{#each config.applicationTypes as |name key|}}
                <option value="{{key}}">{{localize name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>

        {{#if (ne system.application.type "none")}}
          <div class="form-group">
            <label>{{localize "ANIMUS.Formula"}}</label>
            <input type="text" name="system.application.formula" value="{{system.application.formula}}" placeholder="Ex: 2d6 + 4"/>
          </div>
          <div class="form-group">
            <label>{{localize "ANIMUS.SuccessEffect"}}</label>
            <input type="text" name="system.application.onSuccess" value="{{system.application.onSuccess}}"/>
          </div>
        {{/if}}

        {{#if (eq system.application.type "damage")}}
          <div class="form-group">
            <label>{{localize "ANIMUS.Type"}}</label>
            <select name="system.application.damageType">
              {{#select system.application.damageType}}
                {{#each config.weaponTypes as |name key|}}
                  <option value="{{key}}">{{localize name}}</option>
                {{/each}}
              {{/select}}
            </select>
          </div>
        {{/if}}

        {{#if (eq system.application.type "heal")}}
          <div class="form-group">
            <label>{{localize "ANIMUS.Resource"}}</label>
            <select name="system.application.resource">
              {{#select system.application.resource}}
                {{#each config.resources as |name key|}}
                  <option value="{{key}}">{{localize name}}</option>
                {{/each}}
              {{/select}}
            </select>
          </div>
        {{/if}}

        {{#if (eq system.application.type "condition")}}
          <div class="form-group">
            <label>{{localize "ANIMUS.ConditionName"}}</label>
            <input type="text" name="system.application.condition" value="{{system.application.condition}}"/>
          </div>
        {{/if}}
      </div>

      <hr>

      {{#if (eq item.type "weapon")}}
        <div class="form-group">
          <label>{{localize "ANIMUS.DamageTable"}}</label>
          <div class="damage-grid-header">
            <span></span>
            <span>Base</span>
            <span>Mult</span>
          </div>
          {{#each (list "ac1" "ac2" "ac3" "ac4") as |ac|}}
            <div class="damage-row">
              <label>{{upper ac}}</label>
              <input type="number" name="system.damage.{{ac}}.base" value="{{lookup (lookup ../system.damage ac) 'base'}}"/>
              <span>+</span>
              <input type="number" name="system.damage.{{ac}}.mult" value="{{lookup (lookup ../system.damage ac) 'mult'}}"/>
              <span class="mult-label">x {{../system.attribute}}</span>
            </div>
          {{/each}}
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Type"}}</label>
          <select name="system.type">
            {{#select system.type}}
              {{#each config.weaponTypes as |name key|}}
                <option value="{{key}}">{{localize name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Attribute"}}</label>
          <select name="system.attribute">
            {{#select system.attribute}}
              {{#each config.attributesEnum as |name key|}}
                <option value="{{key}}">{{name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Range"}}</label>
          <select name="system.range">
            {{#select system.range}}
              {{#each config.weaponRanges as |name key|}}
                <option value="{{key}}">{{localize name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
      {{/if}}

      {{#if (eq item.type "armor")}}
        <div class="form-group">
          <label>{{localize "ANIMUS.Protection"}}</label>
          <input type="number" name="system.protection" value="{{system.protection}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Penalty"}}</label>
          <input type="number" name="system.penalty" value="{{system.penalty}}"/>
        </div>
      {{/if}}

      {{#if (eq item.type "talent")}}
        <div class="form-group">
          <label>{{localize "ANIMUS.Cost"}} (PE)</label>
          <input type="number" name="system.cost" value="{{system.cost}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Action"}} (PA)</label>
          <input type="number" name="system.action" value="{{system.action}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Type"}}</label>
          <select name="system.type">
            {{#select system.type}}
              {{#each config.talentTypes as |name key|}}
                <option value="{{key}}">{{localize name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Trigger"}}</label>
          <input type="text" name="system.trigger" value="{{system.trigger}}" placeholder="Ex: Ao sofrer dano..."/>
        </div>
      {{/if}}
      
      {{#if (eq item.type "property")}}
        <div class="form-group">
          <label>{{localize "ANIMUS.Action"}} (PA)</label>
          <input type="number" name="system.action" value="{{system.action}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Type"}}</label>
          <select name="system.type">
            {{#select system.type}}
              {{#each config.propertyTypes as |name key|}}
                <option value="{{key}}">{{localize name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.BonusDamage"}}</label>
          <input type="number" name="system.bonus.damage" value="{{system.bonus.damage}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.BonusMult"}}</label>
          <input type="number" name="system.bonus.mult" value="{{system.bonus.mult}}"/>
        </div>
      {{/if}}
      
      {{#if (eq item.type "action")}}
        <div class="form-group">
          <label>{{localize "ANIMUS.Type"}}</label>
          <select name="system.type">
            {{#select system.type}}
              {{#each config.actionTypes as |name key|}}
                <option value="{{key}}">{{localize name}}</option>
              {{/each}}
            {{/select}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.ActionCost"}}</label>
          <input type="number" name="system.cost" value="{{system.cost}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.PECost"}}</label>
          <input type="number" name="system.peCost" value="{{system.peCost}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Trigger"}}</label>
          <input type="text" name="system.trigger" value="{{system.trigger}}"/>
        </div>
      {{/if}}

      <div class="form-group">
          <label>{{localize "ANIMUS.DefenseBonus"}}</label>
          <input type="number" name="system.bonus.defense" value="{{system.bonus.defense}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.DefenseMult"}}</label>
          <input type="number" name="system.bonus.defenseMult" value="{{system.bonus.defenseMult}}"/>
        </div>
        <div class="form-group">
          <label>{{localize "ANIMUS.Reach"}}</label>
          <input type="number" name="system.bonus.reach" value="{{system.bonus.reach}}" step="1.5"/>
        </div>

        <div class="form-group">
          <label>{{localize "ANIMUS.ACBonus"}}</label>
          <div class="ac-bonus-grid">
            {{#each (list "ac1" "ac2" "ac3" "ac4") as |ac|}}
              <div class="ac-input">
                <label>{{upper ac}}</label>
                <input type="number" name="system.bonus.ac.{{ac}}" value="{{lookup ../system.bonus.ac ac}}"/>
              </div>
            {{/each}}
          </div>
        </div>

        <div class="form-group">
          <label>{{localize "ANIMUS.Flags"}}</label>
          <div class="flags-grid">
            <label><input type="checkbox" name="system.flags.isLight" {{checked system.flags.isLight}}/> {{localize "ANIMUS.IsLight"}}</label>
            <label><input type="checkbox" name="system.flags.isVersatile" {{checked system.flags.isVersatile}}/> {{localize "ANIMUS.IsVersatile"}}</label>
            <label><input type="checkbox" name="system.flags.ignoreShields" {{checked system.flags.ignoreShields}}/> {{localize "ANIMUS.IgnoreShields"}}</label>
            <label><input type="checkbox" name="system.flags.isSilent" {{checked system.flags.isSilent}}/> {{localize "ANIMUS.IsSilent"}}</label>
            <label><input type="checkbox" name="system.flags.isThrown" {{checked system.flags.isThrown}}/> {{localize "ANIMUS.IsThrown"}}</label>
          </div>
        </div>
      {{/if}}

      <div class="form-group">
        <label>{{localize "ANIMUS.Weight"}}</label>
        <input type="number" name="system.weight" value="{{system.weight}}"/>
      </div>
      <div class="form-group">
        <label>{{localize "ANIMUS.Price"}}</label>
        <input type="number" name="system.price" value="{{system.price}}"/>
      </div>

      <hr>

      {{!-- Ações Especiais --}}
      <div class="special-actions-section">
        <div class="section-header flexrow">
          <h3>{{localize "ANIMUS.SpecialActions"}}</h3>
          <a class="item-control" data-action="arrayAdd" data-field="specialActions" title="Adicionar Ação"><i class="fas fa-plus"></i></a>
        </div>
        <div class="actions-list">
          {{#each system.specialActions as |actionId index|}}
            <div class="action-row flexrow">
              <input type="text" name="system.specialActions.{{index}}" value="{{actionId}}" placeholder="ID da Ação"/>
              <a class="item-control" data-action="arrayDelete" data-field="specialActions" data-index="{{index}}" title="Remover"><i class="fas fa-trash"></i></a>
            </div>
          {{/each}}
        </div>
      </div>
    </div>
  </section>
</form>
