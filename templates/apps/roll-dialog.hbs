<div class="roll-dialog-content">
  <div class="grid grid-2">
    <div class="form-group">
      <label>Modo de Rolagem</label>
      <select name="advantage">
        <option value="none">Normal</option>
        <option value="advantage">Vantagem</option>
        <option value="disadvantage">Desvantagem</option>
      </select>
    </div>
    <div class="form-group">
      <label>Bônus de Acerto</label>
      <input type="number" name="bonus" value="0" placeholder="Ex: +2, -1..." />
    </div>
  </div>

  <footer class="creator-footer">
    <button type="submit" class="create-btn">
      <i class="fas fa-dice-d20"></i> ROLAR
    </button>
  </footer>
</div>