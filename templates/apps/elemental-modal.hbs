<div class="elemental-modal-container glass-panel">
  <div class="modal-header">
    <img src="{{element.img}}" class="element-icon" />
    <h2>USO ELEMENTAL: {{element.name}}</h2>
  </div>

  <form autocomplete="off">
    <div class="modal-body">
      {{!-- Tipo de Uso --}}
      <div class="form-section">
        <label><i class="fas fa-hand-sparkles"></i>TIPO DE USO</label>
        <div class="radio-group">
          <label class="radio-btn">
            <input type="radio" name="usageType" value="damage" checked />
            <span><i class="fas fa-fire"></i>DANO</span>
          </label>
          <label class="radio-btn">
            <input type="radio" name="usageType" value="heal" />
            <span><i class="fas fa-heart"></i>CURA</span>
          </label>
        </div>
      </div>

      <div class="grid-col-2">
        {{!-- Nível de Potência --}}
        <div class="form-section">
          <label><i class="fas fa-bolt"></i>NÍVEL DE USO</label>
          <select name="level">
            <option value="1">Nível 1 (3 PE Base)</option>
            <option value="2">Nível 2 (6 PE Base)</option>
            <option value="3" {{#unless hasPotencia}}disabled{{/unless}}>
              Nível 3 (9 PE Base) {{#unless hasPotencia}}🔒{{/unless}}
            </option>
          </select>
        </div>

        {{!-- Categoria --}}
        <div class="form-section">
          <label><i class="fas fa-layer-group"></i>CATEGORIA</label>
          <select name="category">
            {{#each categories as |cat key|}}
            <option value="{{key}}" {{#if cat.disabled}}disabled{{/if}}>
              {{cat.label}} {{#if cat.disabled}}🔒{{/if}}
            </option>
            {{/each}}
          </select>
        </div>
      </div>

      <div class="form-section">
        <label><i class="fas fa-arrows-alt-h"></i>ALCANCE / TAMANHO</label>
        <select name="tier">
          {{!-- Populado via JS --}}
        </select>
      </div>

      {{!-- Resumo de Custos --}}
      <div class="cost-summary glass-panel">
        <div class="cost-line">
          <span>Custo de Energia (PE)</span>
          <span class="value total-pe">0 PE</span>
        </div>
        <div class="cost-line">
          <span>Custo de Ações (PA)</span>
          <span class="value total-pa">1 PA</span>
        </div>
        <div class="observation-line text-muted" style="font-size: 0.7rem; margin-top: 5px;"></div>
      </div>
    </div>

    <div class="modal-footer">
      <button type="button" class="btn-cancel" data-action="close">
        <i class="fas fa-times"></i>CANCELAR
      </button>
      <button type="button" class="btn-confirm" data-action="confirm">
        <i class="fas fa-dice-d20"></i>REALIZAR ROLAGEM
      </button>
    </div>
  </form>
</div>
